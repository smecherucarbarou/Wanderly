<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/mapFragment">

    <fragment
        android:id="@+id/onboardingFragment"
        android:name="com.novahorizon.wanderly.ui.onboarding.OnboardingFragment"
        android:label="Onboarding">
        <action
            android:id="@+id/action_onboarding_to_map"
            app:destination="@id/mapFragment"
            app:enterAnim="@anim/fade_in"
            app:exitAnim="@anim/fade_out"
            app:popEnterAnim="@anim/fade_in"
            app:popExitAnim="@anim/fade_out"
            app:popUpTo="@id/onboardingFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/mapFragment"
        android:name="com.novahorizon.wanderly.ui.map.MapFragment"
        android:label="Map">
        <action
            android:id="@+id/action_map_to_missions"
            app:destination="@id/missionsFragment"
            app:enterAnim="@anim/slide_in_right"
            app:launchSingleTop="true"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right"
            app:popUpTo="@id/mapFragment"
            app:popUpToInclusive="false" />
        <action
            android:id="@+id/action_map_to_wanderlyGuide"
            app:destination="@id/wanderlyGuideFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/gemsFragment"
        android:name="com.novahorizon.wanderly.ui.gems.GemsFragment"
        android:label="Gems" />

    <fragment
        android:id="@+id/missionsFragment"
        android:name="com.novahorizon.wanderly.ui.missions.MissionsFragment"
        android:label="Missions" />

    <fragment
        android:id="@+id/socialFragment"
        android:name="com.novahorizon.wanderly.ui.social.SocialFragment"
        android:label="Hive" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.novahorizon.wanderly.ui.profile.ProfileFragment"
        android:label="Profile">
        <action
            android:id="@+id/action_profile_to_devDashboard"
            app:destination="@id/devDashboardFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/devDashboardFragment"
        android:name="com.novahorizon.wanderly.ui.profile.DevDashboardFragment"
        android:label="Dev Panel" />

    <fragment
        android:id="@+id/wanderlyGuideFragment"
        android:name="com.novahorizon.wanderly.ui.guide.WanderlyGuideFragment"
        android:label="@string/wanderly_guide_title" />
</navigation>
