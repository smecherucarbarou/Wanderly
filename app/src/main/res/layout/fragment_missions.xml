<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/background">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:clipToPadding="false">

        <LinearLayout
            android:id="@+id/top_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:padding="8dp">

            <TextView
                android:id="@+id/honey_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🍯 0 Honey"
                android:textColor="@color/primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/rank_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Worker Bee"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/honey_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:progress="0"
            android:max="100"
            android:progressTint="@color/primary"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/top_bar" />

        <ImageView
            android:id="@+id/buzzy_tip"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/ic_buzzy"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/honey_progress"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/buzzy_bubble"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/buzz_before_mission"
            android:background="@drawable/bg_card_honeycomb"
            android:padding="16dp"
            android:elevation="4dp"
            android:textColor="@color/text_primary"
            android:layout_marginStart="16dp"
            android:minHeight="60dp"
            android:gravity="center_vertical"
            app:layout_constraintTop_toTopOf="@id/buzzy_tip"
            app:layout_constraintStart_toEndOf="@id/buzzy_tip"
            app:layout_constraintEnd_toEndOf="parent" />

        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/buzzy_barrier"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="buzzy_tip,buzzy_bubble" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/mission_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_honeycomb"
            android:padding="24dp"
            android:elevation="6dp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="16dp"
            app:layout_constraintTop_toBottomOf="@id/buzzy_barrier">

            <TextView
                android:id="@+id/mission_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No active mission. Generate a New Flight!"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:minLines="3"
                app:layout_constraintTop_toTopOf="parent" />

            <ProgressBar
                android:id="@+id/loading_indicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:indeterminateTint="@color/primary"
                app:layout_constraintTop_toBottomOf="@id/mission_text"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="16dp" />

            <Button
                android:id="@+id/new_flight_button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/generate_mission"
                android:background="@drawable/bg_button_gradient"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:layout_marginTop="24dp"
                app:layout_constraintTop_toBottomOf="@id/loading_indicator"
                app:layout_goneMarginTop="24dp" />

            <Button
                android:id="@+id/verify_button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Verify Location"
                android:backgroundTint="@color/accent"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/new_flight_button" />

            <Button
                android:id="@+id/complete_button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/complete_mission"
                android:background="@drawable/bg_button_gradient"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/verify_button" />

            <Button
                android:id="@+id/learn_more_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Learn more about this place 🕵️"
                android:backgroundTint="@color/secondary"
                android:textColor="@color/primary"
                android:textAllCaps="false"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/complete_button" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <LinearLayout
            android:id="@+id/dev_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:background="#11000000"
            android:padding="8dp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="32dp"
            app:layout_constraintTop_toBottomOf="@id/mission_card"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/dev_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="DEBUG TOOLS"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:gravity="center" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/dev_skip_button"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Skip Verify"
                    android:textSize="10sp"
                    android:layout_weight="1" />

                <Button
                    android:id="@+id/dev_force_button"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Force Gen"
                    android:textSize="10sp"
                    android:layout_weight="1" />
            </LinearLayout>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>