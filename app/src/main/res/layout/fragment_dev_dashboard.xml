<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="24dp">

    <TextView
        android:id="@+id/dev_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Control Room"
        android:textColor="@color/primary"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/dev_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Live tools for stats, notifications, and worker runs."
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dev_title" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dev_subtitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Modify Stats"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/edit_honey"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Honey"
                        android:inputType="number"
                        android:textColor="@color/text_primary" />

                    <EditText
                        android:id="@+id/edit_streak"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Streak"
                        android:inputType="number"
                        android:textColor="@color/text_primary" />

                    <EditText
                        android:id="@+id/edit_flights"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Flights (updates honey/50)"
                        android:inputType="number"
                        android:textColor="@color/text_primary" />

                    <Button
                        android:id="@+id/btn_update_stats"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Update Reality (Honey &amp; Streak)" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Notification Sandbox"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Every trigger here bypasses cooldowns so you can test instantly."
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/edit_friend_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:hint="Target rival name"
                        android:textColor="@color/text_primary" />

                    <Button
                        android:id="@+id/btn_notify_streak"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Daily Streak Reminder"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btn_reset_daily_cooldown"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Reset Daily Reminder Cooldown"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btn_notify_evening"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Evening Rescue Alert"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btn_reset_evening_cooldown"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Reset Evening Alert Cooldown"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btn_notify_milestone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Milestone Celebration"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btn_reset_milestone_cooldown"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Reset Milestone Cooldown"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btn_notify_lost"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Streak Lost Alert"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btn_reset_lost_cooldown"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Reset Streak Lost Cooldown"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btn_notify_rival"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Rival Activity Alert"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btn_reset_rival_cooldown"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Reset Rival Activity Cooldown"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btn_notify_overtaken"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Overtaken Alert"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btn_reset_overtaken_cooldown"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Reset Overtaken Cooldown"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btn_notify_fight"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Fight for First"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btn_reset_fight_cooldown"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Reset Fight for First Cooldown"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btn_clear_notif_cooldowns"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:backgroundTint="@color/error"
                        android:text="Reset All Notification State"
                        android:textAllCaps="false" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AI Notification Preview"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Generates one polished reminder from live profile data and sends the final result immediately."
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <Button
                        android:id="@+id/btn_test_ai_notif"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Generate AI Reminder + Send"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btn_raw_logs"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Show Live Profile JSON"
                        android:textAllCaps="false" />

                    <TextView
                        android:id="@+id/tv_ai_logs"
                        android:layout_width="match_parent"
                        android:layout_height="280dp"
                        android:layout_marginTop="8dp"
                        android:background="#1A000000"
                        android:fontFamily="monospace"
                        android:padding="8dp"
                        android:scrollbars="vertical"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Background Tools"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btn_reset_visit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:backgroundTint="@color/error"
                        android:text="Reset Last Visit (Test Background)"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btn_run_workers"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:backgroundTint="@color/primary"
                        android:text="Force Run Background Workers"
                        android:textAllCaps="false" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
