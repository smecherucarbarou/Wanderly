<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <TextView
        android:id="@+id/dev_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/dev_dashboard_title"
        android:textColor="@color/primary"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/dev_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/dev_dashboard_subtitle"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dev_title" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dev_subtitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dev_dashboard_modify_stats"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/edit_honey"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/dev_dashboard_honey_hint"
                        android:importantForAutofill="no"
                        android:inputType="number"
                        android:textColor="@color/text_primary" />

                    <EditText
                        android:id="@+id/edit_streak"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/dev_dashboard_streak_hint"
                        android:importantForAutofill="no"
                        android:inputType="number"
                        android:textColor="@color/text_primary" />

                    <EditText
                        android:id="@+id/edit_flights"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/dev_dashboard_flights_hint"
                        android:importantForAutofill="no"
                        android:inputType="number"
                        android:textColor="@color/text_primary" />

                    <Button
                        android:id="@+id/btn_update_stats"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/dev_dashboard_update_reality" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dev_dashboard_notification_sandbox"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/dev_dashboard_notification_subtitle"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/edit_friend_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:hint="@string/dev_dashboard_target_rival_hint"
                        android:importantForAutofill="no"
                        android:inputType="text"
                        android:textColor="@color/text_primary" />

                    <Button
                        android:id="@+id/btn_notify_streak"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/dev_dashboard_notify_streak"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btn_reset_daily_cooldown"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/dev_dashboard_reset_daily_cooldown"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btn_notify_evening"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/dev_dashboard_notify_evening"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btn_reset_evening_cooldown"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/dev_dashboard_reset_evening_cooldown"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btn_notify_milestone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/dev_dashboard_notify_milestone"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btn_reset_milestone_cooldown"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/dev_dashboard_reset_milestone_cooldown"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btn_notify_lost"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/dev_dashboard_notify_lost"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btn_reset_lost_cooldown"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/dev_dashboard_reset_lost_cooldown"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btn_notify_rival"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/dev_dashboard_notify_rival"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btn_reset_rival_cooldown"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/dev_dashboard_reset_rival_cooldown"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btn_notify_overtaken"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/dev_dashboard_notify_overtaken"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btn_reset_overtaken_cooldown"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/dev_dashboard_reset_overtaken_cooldown"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btn_notify_fight"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/dev_dashboard_notify_fight"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btn_reset_fight_cooldown"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/dev_dashboard_reset_fight_cooldown"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btn_clear_notif_cooldowns"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:backgroundTint="@color/error"
                        android:text="@string/dev_dashboard_clear_notification_state"
                        android:textAllCaps="false" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dev_dashboard_ai_preview_title"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/dev_dashboard_ai_preview_subtitle"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <Button
                        android:id="@+id/btn_test_ai_notif"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/dev_dashboard_ai_generate"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btn_raw_logs"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/dev_dashboard_show_profile_json"
                        android:textAllCaps="false" />

                    <TextView
                        android:id="@+id/tv_ai_logs"
                        android:layout_width="match_parent"
                        android:layout_height="280dp"
                        android:layout_marginTop="8dp"
                        android:background="@color/dev_log_background"
                        android:fontFamily="monospace"
                        android:padding="8dp"
                        android:scrollbars="vertical"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dev_dashboard_background_tools"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btn_reset_visit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:backgroundTint="@color/error"
                        android:text="@string/dev_dashboard_reset_visit"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btn_replay_onboarding"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/dev_dashboard_replay_onboarding"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btn_run_workers"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:backgroundTint="@color/primary"
                        android:text="@string/dev_dashboard_force_run_workers"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btn_crashlytics_nonfatal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:backgroundTint="@color/primary"
                        android:text="@string/dev_dashboard_send_crashlytics_nonfatal"
                        android:textAllCaps="false" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
