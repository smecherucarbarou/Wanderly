<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="8dp">

    <View
        android:id="@+id/badge_background"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:background="@drawable/bg_badge_circle"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:id="@+id/badge_icon"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:elevation="5dp"
        android:src="@drawable/ic_honeycomb"
        app:layout_constraintTop_toTopOf="@id/badge_background"
        app:layout_constraintBottom_toBottomOf="@id/badge_background"
        app:layout_constraintStart_toStartOf="@id/badge_background"
        app:layout_constraintEnd_toEndOf="@id/badge_background"
        app:tint="@color/card_background" />

    <TextView
        android:id="@+id/badge_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="Badge Name"
        android:textColor="@color/text_primary"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/badge_background"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>