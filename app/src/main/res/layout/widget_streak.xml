<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_widget_streak"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="@dimen/widget_padding">

    <TextView
        android:id="@+id/widget_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/widget_streak_label"
        android:textAllCaps="true"
        android:textColor="#C4A24A"
        android:textSize="11sp"
        android:textStyle="bold" />

    <ImageView
        android:id="@+id/widget_icon"
        android:layout_width="@dimen/widget_icon_frame_size"
        android:layout_height="@dimen/widget_icon_frame_size"
        android:layout_marginTop="12dp"
        android:contentDescription="@null"
        android:src="@drawable/ic_streak_fire" />

    <TextView
        android:id="@+id/widget_streak_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="0"
        android:textColor="@color/pollen_white"
        android:textSize="32sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:maxLines="2"
        android:text="@string/widget_streak_subtitle_normal"
        android:textColor="#EDE6D0"
        android:textSize="13sp" />

</LinearLayout>
