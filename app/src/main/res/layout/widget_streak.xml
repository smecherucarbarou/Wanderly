<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_widget_streak"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="@dimen/widget_padding">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/widget_fire_icon"
            android:layout_width="@dimen/widget_fire_size"
            android:layout_height="@dimen/widget_fire_size"
            android:contentDescription="@null"
            android:src="@drawable/ic_streak_fire" />

        <TextView
            android:id="@+id/widget_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_widget_label_pill"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="@string/widget_streak_label"
            android:textAllCaps="true"
            android:textColor="#E2C27A"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_streak_count"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/widget_spacing_small"
        android:autoSizeMaxTextSize="@dimen/widget_streak_text_size"
        android:autoSizeMinTextSize="24sp"
        android:autoSizeStepGranularity="1sp"
        android:autoSizeTextType="uniform"
        android:gravity="center"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:text="@string/profile_zero_stat"
        android:textColor="@color/accent"
        android:textSize="@dimen/widget_streak_text_size"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_subtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="2"
            android:text="@string/widget_streak_subtitle_proud"
            android:textColor="@color/pollen_white"
            android:textSize="@dimen/widget_subtitle_text_size" />

        <ImageView
            android:id="@+id/widget_mascot"
            android:layout_width="@dimen/widget_mascot_size"
            android:layout_height="@dimen/widget_mascot_size"
            android:layout_marginStart="8dp"
            android:alpha="0.94"
            android:contentDescription="@null"
            android:src="@drawable/widget_mascot_neutral" />
    </LinearLayout>

</LinearLayout>
