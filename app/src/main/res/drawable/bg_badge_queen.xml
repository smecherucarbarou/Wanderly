<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="32dp"
                android:startColor="#E1BEE7"
                android:centerColor="#8E24AA"
                android:endColor="#4A148C" />
            <size android:width="64dp" android:height="64dp" />
            <stroke android:width="2dp" android:color="#BA68C8" />
        </shape>
    </item>
    <item
        android:left="6dp"
        android:top="6dp"
        android:right="6dp"
        android:bottom="28dp">
        <shape android:shape="oval">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#50CE93D8"
                android:endColor="#008E24AA" />
        </shape>
    </item>
</layer-list>
