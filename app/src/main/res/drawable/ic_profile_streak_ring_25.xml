<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="@android:color/transparent" />
            <stroke
                android:width="3dp"
                android:color="#D0FFAB00" />
        </shape>
    </item>
    <item
        android:left="7dp"
        android:top="7dp"
        android:right="7dp"
        android:bottom="7dp">
        <shape android:shape="oval">
            <solid android:color="@android:color/transparent" />
            <stroke
                android:width="2dp"
                android:color="#70FFD54F" />
        </shape>
    </item>
</layer-list>
